  createdBy       User     @relation("OHSVaccinationCreator", fields: [createdById], references: [id])
  
  // Meta
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ohs_vaccinations")
}

// KKD Türü
enum OHSPPEType {
  BARET             // Baret
  KORUYUCU_GOZLUK   // Koruyucu Gözlük
  KULAK_TIKACI      // Kulak Tıkacı/Kulaklık
  TOZ_MASKESI       // Toz Maskesi
  GAZ_MASKESI       // Gaz Maskesi
  ELDIVEN           // İş Eldiveni
  IS_AYAKKABISI     // İş Ayakkabısı
  REFLEKTIF_YELEK   // Reflektif Yelek
  EMNIYET_KEMERI    // Emniyet Kemeri
  KORUYUCU_KIYAFET  // Koruyucu Kıyafet
  YUZ_SIPERLIGI     // Yüz Siperliği
  DIGER             // Diğer
}

// KKD Stok Durumu
enum OHSPPEStatus {
  STOKTA            // Stokta
  AZALIYOR          // Stok Azalıyor
  TUKENDI           // Stok Tükendi
}

// KKD (Kişisel Koruyucu Donanım) Stok
model OHSPPE {
  id              String   @id @default(cuid())
  code            String   @unique  // KKD-YYYY-NNNN
  
  // KKD Bilgileri
  type            OHSPPEType
  name            String            // KKD adı
  brand           String?           // Marka
  model           String?           // Model
  
  // Stok Bilgileri
  stockQuantity   Int      @default(0)
  minStockLevel   Int      @default(10)  // Minimum stok seviyesi
  unit            String   @default("Adet")  // Birim (Adet, Çift, vb.)
  
  // Durum
  status          OHSPPEStatus @default(STOKTA)
  
  // Depo/Konum
  location        String?           // Depo konumu
  
  // Teslim Edilen Departman
  departmentId    String?
  department      Department? @relation("OHSPPEDept", fields: [departmentId], references: [id])
  
  // Oluşturan
  createdById     String
  createdBy       User     @relation("OHSPPECreator", fields: [createdById], references: [id])
  
  // Meta
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // İlişkiler
  distributions   OHSPPEDistribution[]
  
  @@map("ohs_ppe")
}

// KKD Dağıtım Kaydı
model OHSPPEDistribution {
  id              String   @id @default(cuid())
  
  // KKD
  ppeId           String
  ppe             OHSPPE   @relation(fields: [ppeId], references: [id], onDelete: Cascade)
  
  // Personel (teslim alan)
  userId          String?
  user            User?    @relation("OHSPPEDistributionUser", fields: [userId], references: [id])
  recipientName   String?            // Manuel giriş: Teslim alan kişi adı
  
  // Dağıtım Bilgileri
  quantity        Int
  distributionDate DateTime @default(now())
  
  // Zimmet Formu (PDF)
  custodyFormFileName   String?
  custodyFormFileSize   Int?
  custodyFormCloudPath  String?
  custodyFormIsPublic   Boolean @default(false)
  
  // Açıklama
  description     String?
  
  // İade (Opsiyonel)
  returnDate      DateTime?
  returnQuantity  Int?
  returnReason    String?
  
  // Notlar
  notes           String?
  
  // Departman Müdürü (Teslim Eden)
  departmentManagerName String?       // Manuel giriş: Departman müdürü adı
  
  // Dağıtan (Teslim Eden)
  distributedById String
  distributedBy   User     @relation("OHSPPEDistributor", fields: [distributedById], references: [id])
  
  // Meta
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ohs_ppe_distributions")
}

// Acil Durum Türü
enum OHSEmergencyType {
  YANGIN            // Yangın
  DEPREM            // Deprem
  TAHLIYE           // Tahliye
  KIMYASAL_SIZINTI  // Kimyasal Sızıntı
  ELEKTRIK_KESINTISI // Elektrik Kesintisi
  SU_BASKINI        // Su Baskını
  DOGAL_AFET        // Doğal Afet
  SAGLIK_ACIL       // Sağlık Acil Durumu
  GUVENLIK          // Güvenlik Acil Durumu
  DIGER             // Diğer
}

// Acil Durum Planı Durumu
enum OHSEmergencyPlanStatus {
  TASLAK            // Taslak
  AKTIF             // Aktif
  GUNCELLENIYOR     // Güncelleniyor
  ARSIV             // Arşiv
}

// Acil Durum Planı
model OHSEmergencyPlan {
  id              String   @id @default(cuid())
  code            String   @unique  // ADP-YYYY-NNNN
  
  // Plan Bilgileri
  type            OHSEmergencyType
  title           String            // Plan adı
  description     String            // Plan açıklaması
  
  // Prosedürler
  procedures      String            // Acil durum prosedürleri
  evacuationRoutes String?          // Tahliye güzergahları
  assemblyPoints  String?           // Toplanma noktaları
  
  // Sorumlular
  responsiblePersons String?        // Sorumlu kişiler/ekipler
  emergencyContacts  String?        // Acil durum iletişim numaraları
  
  // Doküman
  documentFileName    String?
  documentFileSize    Int?
  documentFileType    String?
  documentCloudPath   String?
  documentIsPublic    Boolean  @default(false)
  
  // Durum ve Versiyon
  status          OHSEmergencyPlanStatus @default(TASLAK)
  version         String   @default("1.0")
  validFrom       DateTime?
  validUntil      DateTime?
  
  // Oluşturan
  createdById     String
  createdBy       User     @relation("OHSEmergencyPlanCreator", fields: [createdById], references: [id])
  
  // Meta
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // İlişkiler
  drills          OHSEmergencyDrill[]
  
  @@map("ohs_emergency_plans")
}

// Tatbikat Sonucu
enum OHSDrillResult {
  BASARILI          // Başarılı
  KISMEN_BASARILI   // Kısmen Başarılı
  BASARISIZ         // Başarısız
}

// Acil Durum Tatbikatı
model OHSEmergencyDrill {
  id              String   @id @default(cuid())
  code            String   @unique  // TAT-YYYY-NNNN
  
  // Tatbikat Bilgileri
  planId          String
  plan            OHSEmergencyPlan @relation(fields: [planId], references: [id])
  
  title           String            // Tatbikat adı
  drillDate       DateTime          // Tatbikat tarihi
  duration        Int?              // Süre (dakika)
  
  // Katılımcılar
  participantCount Int?             // Katılımcı sayısı
  departments     String?           // Katılan departmanlar
  
  // Sonuç
  result          OHSDrillResult?
  findings        String?           // Bulgular
  improvements    String?           // İyileştirme önerileri
  
  // Rapor
  reportFileName      String?
  reportFileSize      Int?
  reportFileType      String?
  reportCloudPath     String?
  reportIsPublic      Boolean  @default(false)
  
  // Oluşturan
  createdById     String
  createdBy       User     @relation("OHSEmergencyDrillCreator", fields: [createdById], references: [id])
  
  // Meta
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ohs_emergency_drills")
}

// ============================================
// HACCP & GIDA GÜVENLİĞİ YÖNETİMİ
// ============================================

enum HACCPEquipmentType {
  BUZDOLABI         // Buzdolabı
  DERIN_DONDURUCU   // Derin dondurucu
  SICAK_TUTUCU      // Sıcak tutucu
  ACIK_BUFE         // Açık büfe
  FIRIN             // Fırın
  PISIRME_EKIPMAN   // Pişirme ekipmanı
  DIGER             // Diğer
}

enum HACCPEquipmentStatus {
  AKTIF     // Aktif
  BAKIMDA   // Bakımda
  ARIZALI   // Arızalı
  PASIF     // Pasif
}

enum HACCPMeasurementFrequency {
  SAATLIK       // Saatlik
  VARDIYA_BASI  // Vardiya başı
  GUNDE_3_KEZ   // Günde 3 kez
  GUNDE_2_KEZ   // Günde 2 kez
  GUNLUK        // Günlük
}

enum HACCPCCPProcess {
  PISIRME   // Pişirme
  SOGUTMA   // Soğutma
  SAKLAMA   // Saklama
  SERVIS    // Servis
  HAZIRLIK  // Hazırlık
  TESLIM    // Teslim alma
}

enum HACCPChecklistStatus {
  YAPILDI    // Yapıldı
  YAPILMADI  // Yapılmadı
  UYGUNSUZ   // Uygunsuz
}

enum HACCPPestAreaType {
  MUTFAK     // Mutfak
  DEPO       // Depo
  COP_ALANI  // Çöp alanı
  RESTORAN   // Restoran
  BAHCE      // Bahçe
  TEKNIK     // Teknik alan
  DIGER      // Diğer
}

enum HACCPPestStationStatus {
  TEMIZ          // Temiz
  AKTIVITE_VAR   // Aktivite var
  HASARLI        // Hasarlı
  DEGISTIRILDI   // Değiştirildi
}

enum HACCPPestControlFrequency {
  HAFTALIK   // Haftalık
  AYLIK      // Aylık
  IKI_AYLIK  // İki aylık
  UC_AYLIK   // Üç aylık
}

// HACCP Ekipman Tanımları (Buzdolabı, Dondurucu, vb.)
model HACCPEquipment {
  id               String                    @id @default(cuid())
  code             String                    @unique  // EKP-YYYY-NNNN
  name             String
  type             HACCPEquipmentType
  location         String
  brand            String?
  model            String?
  serialNumber     String?

  // Sıcaklık limitleri
  minTemp          Float?
  maxTemp          Float?
  targetTemp       Float?

  // Ölçüm periyodu
  measurementFrequency HACCPMeasurementFrequency?

  status           HACCPEquipmentStatus      @default(AKTIF)
  notes            String?

  temperatureLogs  HACCPTemperatureLog[]

  createdById      String
  createdBy        User     @relation("HACCPEquipmentCreator", fields: [createdById], references: [id])

  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("haccp_equipment")
}

// HACCP Sıcaklık Kayıtları
model HACCPTemperatureLog {
  id               String          @id @default(cuid())

  equipmentId      String
  equipment        HACCPEquipment  @relation(fields: [equipmentId], references: [id])

  temperature      Float
  measuredAt       DateTime
  isOutOfRange     Boolean         @default(false)

  notes            String?

  // Düzeltici Faaliyet
  correctiveAction   String?
  correctiveActionAt DateTime?
  correctiveActionById String?
  correctiveActionBy   User?   @relation("HACCPCorrectiveActionBy", fields: [correctiveActionById], references: [id])

  measuredById     String
  measuredBy       User    @relation("HACCPTemperatureMeasurer", fields: [measuredById], references: [id])

  createdAt        DateTime @default(now())

  @@map("haccp_temperature_logs")
}

// HACCP Kritik Kontrol Noktaları (CCP)
model HACCPCCP {
  id                  String          @id @default(cuid())
  code                String          @unique  // CCP-YYYY-NNNN
  name                String
  process             HACCPCCPProcess
  description         String?

  criticalLimitMin    Float?
  criticalLimitMax    Float?
  criticalLimitUnit   String?
  criticalLimitDesc   String?

  monitoringMethod    String?
  monitoringFrequency String?

  responsibleId       String?
  responsible         User?   @relation("CCPResponsible", fields: [responsibleId], references: [id])

  correctiveProcedure String?

  isActive            Boolean @default(true)

  checklists          HACCPCCPChecklist[]

  createdById         String
  createdBy           User    @relation("HACCPCCPCreator", fields: [createdById], references: [id])

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("haccp_ccps")
}

// HACCP CCP Günlük Kontrol Listesi
model HACCPCCPChecklist {
  id             String               @id @default(cuid())

  ccpId          String
  ccp            HACCPCCP             @relation(fields: [ccpId], references: [id])

  checkDate      DateTime
  status         HACCPChecklistStatus
  measuredValue  Float?
  notes          String?

  photoFileName  String?
  photoFileSize  Int?
  photoFileType  String?
  photoCloudPath String?

  nonConformity  String?
  capaCreated    Boolean  @default(false)
  capaId         String?

  isApproved     Boolean  @default(false)
  approvedById   String?
  approvedBy     User?    @relation("CCPChecklistApprover", fields: [approvedById], references: [id])
  approvedAt     DateTime?

  checkedById    String
  checkedBy      User     @relation("CCPChecklistChecker", fields: [checkedById], references: [id])

  createdAt      DateTime @default(now())

  @@map("haccp_ccp_checklists")
}

// HACCP Haşere Kontrol İstasyonları
model HACCPPestStation {
  id               String                    @id @default(cuid())
  code             String                    @unique  // PST-YYYY-NNNN
  name             String
  areaType         HACCPPestAreaType
  location         String
  stationType      String?

  controlFrequency HACCPPestControlFrequency @default(HAFTALIK)
  lastControlDate  DateTime?
  nextControlDate  DateTime?

  isActive         Boolean @default(true)

  pestLogs         HACCPPestLog[]

  createdById      String
  createdBy        User    @relation("HACCPPestStationCreator", fields: [createdById], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("haccp_pest_stations")
}

// HACCP Haşere Kontrol Kayıtları
model HACCPPestLog {
  id              String                 @id @default(cuid())

  stationId       String
  station         HACCPPestStation       @relation(fields: [stationId], references: [id])

  controlDate     DateTime
  status          HACCPPestStationStatus
  findings        String?

  externalCompany String?

  reportFileName  String?
  reportFileSize  Int?
  reportFileType  String?
  reportCloudPath String?

  actionRequired  Boolean @default(false)
  actionTaken     String?

  inspectedById   String
  inspectedBy     User    @relation("HACCPPestInspector", fields: [inspectedById], references: [id])

  createdAt       DateTime @default(now())

  @@map("haccp_pest_logs")
}

// HACCP Gıda Numune Takibi
model HACCPFoodSample {
  id             String    @id @default(cuid())
  code           String    @unique  // NMN-YYYY-NNNN

  productName    String
  sampleDate     DateTime
  sampleTime     String?
  mealType       String?

  storageTemp    Float?
  retentionHours Int       @default(72)
  expiryDateTime DateTime

  isExpired      Boolean   @default(false)
  isDisposed     Boolean   @default(false)
  disposedAt     DateTime?
  disposedById   String?
  disposedBy     User?     @relation("HACCPSampleDisposer", fields: [disposedById], references: [id])

  labelFileName  String?
  labelFileSize  Int?
  labelFileType  String?
  labelCloudPath String?

  notes          String?

  createdById    String
  createdBy      User      @relation("HACCPFoodSampleCreator", fields: [createdById], references: [id])

  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("haccp_food_samples")
}

// HACCP Temizlik Alan Tanımları
model HACCPCleaningArea {
  id             String    @id @default(cuid())
  name           String
  areaType       String
  description    String?

  checklistItems String    // JSON array of checklist item strings

  frequency      String    @default("GUNLUK")

  isActive       Boolean   @default(true)

  cleaningLogs   HACCPCleaningLog[]

  createdById    String
  createdBy      User      @relation("HACCPCleaningAreaCreator", fields: [createdById], references: [id])

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("haccp_cleaning_areas")
}

// HACCP Temizlik Kontrol Kayıtları
model HACCPCleaningLog {
  id               String    @id @default(cuid())

  areaId           String
  area             HACCPCleaningArea @relation(fields: [areaId], references: [id])

  logDate          DateTime
  shift            String?

  checklistResults String    // JSON: [{item, done, note}]

  overallStatus    String    @default("TAMAM")
  notes            String?

  actionRequired   Boolean   @default(false)
  actionTaken      String?

  isSignedOff      Boolean   @default(false)
  signedOffById    String?
  signedOffBy      User?     @relation("HACCPCleaningSignOff", fields: [signedOffById], references: [id])
  signedOffAt      DateTime?

  performedById    String
  performedBy      User      @relation("HACCPCleaningPerformer", fields: [performedById], references: [id])

  createdAt        DateTime  @default(now())

  @@map("haccp_cleaning_logs")
}

// ==========================================
// ENERJİ & ÇEVRE YÖNETİMİ (SUSTAINABILITY)
// ==========================================

// Sayaç Türleri: ELEKTRIK, DOGALGAZ, LPG, JENERATOR, SU
// Sayaç Seviyeleri: ANA, ALT

model SustainabilityMeter {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  type         String   // ELEKTRIK | DOGALGAZ | LPG | JENERATOR | SU
  category     String   // ENERJI | SU
  level        String   @default("ALT")  // ANA | ALT
  location     String   // mutfak, spa, odalar, bahce vb.
  unit         String   // kWh, m3, litre
  parentId     String?
  parent       SustainabilityMeter?  @relation("MeterHierarchy", fields: [parentId], references: [id])
  children     SustainabilityMeter[] @relation("MeterHierarchy")
  isActive     Boolean  @default(true)
  notes        String?

  readings     SustainabilityReading[]

  createdById  String
  createdBy    User     @relation("SustMeterCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sustainability_meters")
}

model SustainabilityReading {
  id           String   @id @default(cuid())
  meterId      String
  meter        SustainabilityMeter @relation(fields: [meterId], references: [id])
  readingDate  DateTime
  period       String   // GUNLUK | HAFTALIK | AYLIK
  value        Float    // Tüketim miktarı (kWh, m3, litre)
  cost         Float?   // Maliyet (TL)
  occupancyRate Float?  // Doluluk oranı (%)
  guestCount   Int?     // Misafir sayısı
  notes        String?
  isAnomalous  Boolean  @default(false)
  alertSent    Boolean  @default(false)

  createdById  String
  createdBy    User     @relation("SustReadingCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@map("sustainability_readings")
}

model SustainabilityWasteRecord {
  id           String   @id @default(cuid())
  code         String   @unique
  recordDate   DateTime
  period       String   @default("GUNLUK")  // GUNLUK | HAFTALIK
  wasteType    String   // ORGANIK | PLASTIK | CAM | KAGIT | TEHLIKELI | DIGER
  area         String   // mutfak, bar, housekeeping vb.
  quantity     Float    // kg
  isRecycled   Boolean  @default(false)
  disposalFirm String?  // Lisanslı firma adı
  waybillNo    String?  // İrsaliye no
  notes        String?

  attachmentFileName  String?
  attachmentFileSize  Int?
  attachmentFileType  String?
  attachmentCloudPath String?

  createdById  String
  createdBy    User     @relation("SustWasteCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sustainability_waste_records")
}

model SustainabilityEmissionFactor {
  id           String   @id @default(cuid())
  sourceType   String   @unique  // ELEKTRIK | DOGALGAZ | LPG | JENERATOR | SU
  factor       Float    // kg CO2 per unit
  unit         String   // per kWh, per m3, etc.
  year         Int
  source       String?  // IPCC, DEFRA, vb.
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sustainability_emission_factors")
}

model SustainabilityTarget {
  id           String   @id @default(cuid())
  code         String   @unique
  title        String
  category     String   // ENERJI | SU | ATIK | KARBON
  metricType   String   // Hangi KPI (kWh_PER_ROOM, LITRE_PER_GUEST, vb.)
  baselineValue Float   // Baz değer
  targetValue  Float    // Hedef değer
  targetUnit   String   // %, kWh, litre, kg
  reductionPct Float    // Azaltım yüzdesi hedefi
  period       String   // AYLIK | YILLIK
  startDate    DateTime
  endDate      DateTime
  status       String   @default("AKTIF")  // AKTIF | TAMAMLANDI | IPTAL

  actions      SustainabilityAction[]

  createdById  String
  createdBy    User     @relation("SustTargetCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sustainability_targets")
}

model SustainabilityAction {
  id           String   @id @default(cuid())
  targetId     String
  target       SustainabilityTarget @relation(fields: [targetId], references: [id])
  title        String
  description  String?
  assignedToId String?
  assignedTo   User?    @relation("SustActionAssignee", fields: [assignedToId], references: [id])
  dueDate      DateTime?
  status       String   @default("ACIK")  // ACIK | DEVAM_EDIYOR | TAMAMLANDI | IPTAL
  priority     String   @default("ORTA")  // DUSUK | ORTA | YUKSEK
  completedAt  DateTime?
  notes        String?

  createdById  String
  createdBy    User     @relation("SustActionCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sustainability_actions")
}

model SustainabilityAlert {
  id           String   @id @default(cuid())
  category     String   // ENERJI | SU | ATIK | KARBON
  alertType    String   // LIMIT_ASIMI | ANOMALI | HEDEF_SAPMA
  severity     String   @default("UYARI")  // BILGI | UYARI | KRITIK
  title        String
  message      String
  meterId      String?
  readingId    String?
  isRead       Boolean  @default(false)
  isResolved   Boolean  @default(false)
  resolvedById String?
  resolvedBy   User?    @relation("SustAlertResolver", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())

  @@map("sustainability_alerts")
}

// ============================================================
// LQA (Leading Quality Assurance) Modülü
// ============================================================

enum LQAAuditType {
  IC
  DIS
  MYSTERY
}

enum LQAAuditStatus {
  TASLAK
  DEVAM_EDIYOR
  TAMAMLANDI
  IPTAL
}

enum LQACriteriaResult {
  EVET
  HAYIR
  NA
}

model LQACategory {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String?
  icon        String?
  order       Int           @default(0)
  isActive    Boolean       @default(true)
  weight      Float         @default(1.0)

  criteria    LQACriteria[]
  auditItems  LQAAuditItem[]
  scores      LQAAuditScore[]
  targets     LQATarget[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("lqa_categories")
}

model LQACriteria {
  id          String        @id @default(cuid())
  categoryId  String
  category    LQACategory   @relation(fields: [categoryId], references: [id])
  code        String        @unique
  description String
  guidance    String?
  weight      Float         @default(1.0)
  isCritical  Boolean       @default(false)
  isActive    Boolean       @default(true)
  order       Int           @default(0)

  auditItems  LQAAuditItem[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("lqa_criteria")
}

model LQAAudit {
  id                  String          @id @default(cuid())
  code                String          @unique
  title               String
  auditType           LQAAuditType    @default(IC)
  status              LQAAuditStatus  @default(TASLAK)
  auditDate           DateTime

  selectedCategories  String[]
  roomNumbers         String?
  areaName            String?

  auditorId           String?
  auditor             User?           @relation("LQAAuditor", fields: [auditorId], references: [id])
  auditorName         String?

  mysteryGuestEmail   String?
  mysteryGuestToken   String?         @unique

  overallScore        Float?
  notes               String?

  items               LQAAuditItem[]
  scores              LQAAuditScore[]

  createdById         String
  createdBy           User            @relation("LQAAuditCreator", fields: [createdById], references: [id])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@map("lqa_audits")
}

model LQAAuditItem {
  id          String              @id @default(cuid())
  auditId     String
  audit       LQAAudit            @relation(fields: [auditId], references: [id], onDelete: Cascade)
  criteriaId  String
  criteria    LQACriteria         @relation(fields: [criteriaId], references: [id])
  categoryId  String
  category    LQACategory         @relation(fields: [categoryId], references: [id])

  result      LQACriteriaResult?
  score       Float?
  notes       String?
  photoUrl    String?

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([auditId, criteriaId])
  @@map("lqa_audit_items")
}

model LQAAuditScore {
  id           String      @id @default(cuid())
  auditId      String
  audit        LQAAudit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  categoryId   String
  category     LQACategory @relation(fields: [categoryId], references: [id])

  totalPoints  Float
  earnedPoints Float
  score        Float

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([auditId, categoryId])
  @@map("lqa_audit_scores")
}

model LQATarget {
  id          String       @id @default(cuid())
  categoryId  String?
  category    LQACategory? @relation(fields: [categoryId], references: [id])
  targetType  String       @default("GENEL")
  targetName  String
  score       Float
  period      String       @default("YILLIK")
  year        Int

  createdById String
  createdBy   User         @relation("LQATargetCreator", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("lqa_targets")
}