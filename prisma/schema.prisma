// Aşı Türü
enum OHSVaccineType {
  TETANOS           // Tetanos
  HEPATIT_A         // Hepatit A
  HEPATIT_B         // Hepatit B
  GRIP              // Grip (Influenza)
  KOVID             // COVID-19
  KUDUZ             // Kuduz
  DIGER             // Diğer
}

// Aşı Kaydı
model OHSVaccination {
  id              String   @id @default(cuid())
  
  // Personel
  userId          String
  user            User     @relation("OHSVaccinationUser", fields: [userId], references: [id])
  
  // Aşı Bilgileri
  vaccineType     OHSVaccineType
  vaccineName     String?           // Özel aşı adı
  vaccineDate     DateTime          // Aşı tarihi
  nextDoseDate    DateTime?         // Sonraki doz tarihi
  doseNumber      Int      @default(1)  // Kaçıncı doz
  
  // Uygulayan
  administeredBy  String?           // Uygulayan hekim/kurum
  batchNumber     String?           // Lot numarası
  
  // Notlar
  notes           String?
  
  // Oluşturan
