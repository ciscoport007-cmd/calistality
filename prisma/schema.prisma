  reporter        User?    @relation("OHSNearMissReporter", fields: [reporterId], references: [id])
  reporterName    String?            // Manuel giriş: Bildiren kişi adı
  
  // Ne Olabilirdi
  potentialConsequence String?       // Olası sonuç
  
  // Önerilen Önlem ve Sorumlu
  suggestedMeasure String?           // Önerilen önlem
  responsibleNote  String?           // Sorumlu notu
  responsibleName  String?           // Sorumlu kişi adı
  
  // Kanıt Doküman (Opsiyonel)
  evidenceFileName     String?
  evidenceFileSize     Int?
  evidenceFileType     String?
  evidenceCloudPath    String?
  evidenceIsPublic     Boolean  @default(false)
  
  // Durum
  status          String   @default("ACIK")  // ACIK, TAMAMLANDI
  completedAt     DateTime?
  
  // Oluşturan
  createdById     String
  createdBy       User     @relation("OHSNearMissCreator", fields: [createdById], references: [id])
  
  // Meta
  isActive        Boolean  @default(true)
