// İSG Risk Kaynakları
enum OHSRiskSource {
  TASERON                // Taşeron
  EKIPMAN                // Ekipman
  CEVRE                  // Çevre
  INSAN                  // İnsan Faktörü
  PROSES                 // Proses/İş Süreci
  KIMYASAL               // Kimyasal
  FIZIKSEL               // Fiziksel
  BIYOLOJIK              // Biyolojik
  ERGONOMIK              // Ergonomik
  DIGER                  // Diğer
}

// İSG Risk Durumu
enum OHSRiskStatus {
  ACIK                   // Açık
  AKSIYON_BEKLIYOR       // Aksiyon Bekliyor
  DEGERLENDIRMEDE        // Değerlendirmede
  KAPATILDI              // Kapatıldı
}

// İSG Risk Değerlendirme
model OHSRisk {
  id              String   @id @default(cuid())
  code            String   @unique  // ISG-YYYY-NNNN formatında
  
  // Temel Bilgiler
  name            String             // Risk Adı
  description     String?            // Açıklama
  source          OHSRiskSource      // Risk Kaynağı
  sourceDetail    String?            // Kaynak detayı (serbest metin)
  category        String   @default("IS_GUVENLIGI") // Sabit: İş Güvenliği
  
  // Departman ve Sorumlu
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  
  ownerId         String
  owner           User     @relation("OHSRiskOwner", fields: [ownerId], references: [id])
  
  // Risk Değerlendirmesi
  likelihood      Int                // Olasılık (1-5)
  impact          Int                // Etki (1-5)
  riskScore       Int                // Risk Puanı (Olasılık × Etki)
  riskLevel       String?            // DUSUK, ORTA, YUKSEK, COK_YUKSEK, KRITIK
  
  // Durum
  status          OHSRiskStatus @default(ACIK)
  
  // Kanıt Doküman (Zorunlu)
  evidenceFileName     String?
  evidenceFileSize     Int?
  evidenceFileType     String?
  evidenceCloudPath    String?
  evidenceIsPublic     Boolean  @default(false)
  
  // Oluşturan
  createdById     String
  createdBy       User     @relation("OHSRiskCreator", fields: [createdById], references: [id])
  
  // Meta
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // İlişkiler
  actions         OHSRiskAction[]
  assessments     OHSRiskAssessment[]
  comments        OHSRiskComment[]
  
  @@map("ohs_risks")
}

// İSG Risk Aksiyon Türü
enum OHSActionType {
  ONLEME                 // Önleme
  DUZELTME               // Düzeltme
  IYILESTIRME            // İyileştirme
  KONTROL                // Kontrol
  EGITIM                 // Eğitim
  DIGER                  // Diğer
}

// İSG Risk Aksiyon Önceliği
enum OHSActionPriority {
  DUSUK                  // Düşük
  ORTA                   // Orta
  YUKSEK                 // Yüksek
}

// İSG Risk Aksiyon Durumu
enum OHSActionStatus {
  OLUSTURULDU            // Oluşturuldu
  DEVAM_EDIYOR           // Devam Ediyor
  TAMAMLANDI             // Tamamlandı
  IPTAL                  // İptal Edildi
}

// İSG Risk Aksiyonları
model OHSRiskAction {
  id              String   @id @default(cuid())
  
  riskId          String
  risk            OHSRisk  @relation(fields: [riskId], references: [id], onDelete: Cascade)
  
  // Aksiyon Bilgileri
  title           String
  description     String?
  actionType      OHSActionType
  priority        OHSActionPriority @default(ORTA)
  
  // Tarihler
  startDate       DateTime?
  dueDate         DateTime?
  completedAt     DateTime?
  
  // Sorumlu
  assigneeId      String
  assignee        User     @relation("OHSRiskActionAssignee", fields: [assigneeId], references: [id])
  
  // Bütçe
  plannedBudget   Float?   @default(0)
  actualCost      Float?
  
  // Durum
  status          OHSActionStatus @default(OLUSTURULDU)
  
  // Tamamlama Kanıtı
  completionEvidenceFileName  String?
  completionEvidenceFileSize  Int?
  completionEvidenceFileType  String?
  completionEvidenceCloudPath String?
  completionEvidenceIsPublic  Boolean  @default(false)
  
  // Tamamlayan
  completedById   String?
  completedBy     User?    @relation("OHSRiskActionCompletedBy", fields: [completedById], references: [id])
  
  // Oluşturan
  createdById     String
  createdBy       User     @relation("OHSRiskActionCreator", fields: [createdById], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ohs_risk_actions")
}

// İSG Risk Değerlendirme Tipi
enum OHSAssessmentType {
  RUTIN                  // Rutin
  OLAY_SONRASI           // Olay Sonrası
  PERIYODIK              // Periyodik
}

// Kontrol Etkinliği
enum ControlEffectiveness {
  ETKILI                 // Etkili
  KISMEN_ETKILI          // Kısmen Etkili
  ETKISIZ                // Etkisiz
}

// İSG Risk Değerlendirme Kayıtları
model OHSRiskAssessment {
  id              String   @id @default(cuid())
  
  riskId          String
  risk            OHSRisk  @relation(fields: [riskId], references: [id], onDelete: Cascade)
  
  // Değerlendirme Bilgileri
  assessmentType  OHSAssessmentType
  likelihood      Int                // Olasılık (1-5)
  impact          Int                // Etki (1-5)
  riskScore       Int                // Otomatik: Olasılık × Etki
  
  // Kontrol Etkinliği
  controlEffectiveness ControlEffectiveness?
  
  // Bulgular ve Öneriler
  findings        String?
  recommendations String?
  
  // Trend (önceki değerlendirmeye göre)
  trend           String?            // AZALDI, ARTTI, AYNI_KALDI
  previousScore   Int?
  
  // Değerlendiren
  createdById     String
  createdBy       User     @relation("OHSRiskAssessmentCreator", fields: [createdById], references: [id])
  
  createdAt       DateTime @default(now())
  
  @@map("ohs_risk_assessments")
}

// İSG Risk Yorumları
model OHSRiskComment {
  id              String   @id @default(cuid())
  
  riskId          String
  risk            OHSRisk  @relation(fields: [riskId], references: [id], onDelete: Cascade)
  
  // Yorum Bilgileri
  content         String
  
  // Yazar
  authorId        String
  author          User     @relation("OHSRiskCommentAuthor", fields: [authorId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ohs_risk_comments")
}

// ============================================
// İŞ KAZALARI VE RAMAK KALA
// ============================================

// İş Kazası Durumu
enum OHSAccidentStatus {
  ACIK                   // Açık - İnceleniyor
  ANALIZ                 // Kök Neden Analizi
  ONLEM_ALIYOR           // Önlem Alınıyor
  KAPATILDI              // Kapatıldı
  TAMAMLANDI             // Tamamlandı - Eğitim dokümanı yüklendi
}

// İş Kazaları
model OHSAccident {
  id              String   @id @default(cuid())
  code            String   @unique  // KAZ-YYYY-NNNN formatında
  
  // Temel Bilgiler
  title           String             // Kaza Adı
  accidentDate    DateTime           // Kaza Tarihi
  location        String             // Kaza Yeri
  
  // Departman
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  
  // Açıklama ve Analiz
  description     String             // Kaza Açıklaması
  rootCauseAnalysis String?          // Kök Neden Analizi
  
  // Alınan Önlemler
  actionsTaken    String?            // Alınan Önlemler
  preventiveMeasures String?         // Tekrar olmaması için aksiyonlar
  
  // Kanıt Doküman (Zorunlu)
  evidenceFileName     String
  evidenceFileSize     Int
  evidenceFileType     String
  evidenceCloudPath    String
  evidenceIsPublic     Boolean  @default(false)
  
  // Durum
  status          OHSAccidentStatus @default(ACIK)
  
  // Eğitim Takibi
  trainingStatus      String?    // EGITIM_ALDI, EGITIM_ALMADI
  trainingDate        DateTime?
  trainingCertFileName    String?
  trainingCertFileSize    Int?
  trainingCertCloudPath   String?
  trainingCertIsPublic    Boolean @default(false)
  trainingCompletedAt     DateTime?
  
  // Oluşturan
  createdById     String
  createdBy       User     @relation("OHSAccidentCreator", fields: [createdById], references: [id])
  
  // Meta
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // İlişkiler
  involvedPersons OHSAccidentPerson[]
  
  @@map("ohs_accidents")
}

// Kazaya Karışan Personel
model OHSAccidentPerson {
  id              String   @id @default(cuid())
  
  accidentId      String
  accident        OHSAccident @relation(fields: [accidentId], references: [id], onDelete: Cascade)
  
  // Personel
  userId          String?
  user            User?    @relation("OHSAccidentPersonUser", fields: [userId], references: [id])
  
  // Harici kişi (sistemde olmayan)
  externalName    String?
  externalRole    String?  // Taşeron çalışanı, ziyaretçi vb.
  
  // Kişi detay bilgileri
  duty            String?  // Görev (dropdown seçimi)
  position        String?  // Pozisyon (dropdown seçimi)
  personDepartmentId String? // Departman ID
  personDepartment   Department? @relation("OHSAccidentPersonDept", fields: [personDepartmentId], references: [id])
  
  // Kimlik bilgileri
  tcKimlikNo      String?  // TC Kimlik No
  birthDate       DateTime? // Doğum tarihi
  
  // Vardiya bilgisi
  shift           String?  // GUNDUZ, GECE, AKSAM, ROTASYONLU
  
  // Kaza sonrası eğitim durumu
  retrainingReceived Boolean @default(false) // Tekrar eğitim aldı mı
  retrainingDate    DateTime? // Eğitim tarihi
  retrainingNotes   String?   // Eğitim notları
  
  // Rapor ve işgöremezlik
  sickLeaveDays     Int?     // Raporlu gün sayısı
  disabilityStatus  String?  // YOK, GECICI, KALICI
  disabilityRate    Int?     // İşgöremezlik oranı (%)
  disabilityNotes   String?  // İşgöremezlik açıklaması
  
  // Notlar
  notes           String?
  
  createdAt       DateTime @default(now())
  
  @@map("ohs_accident_persons")
}

// Ramak Kala
model OHSNearMiss {
  id              String   @id @default(cuid())
  code            String   @unique  // RMK-YYYY-NNNN formatında
  
  // Temel Bilgiler
  title           String             // Olay Adı
  eventDate       DateTime           // Olay Tarihi
  
  // Departman
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  
  // Açıklama
